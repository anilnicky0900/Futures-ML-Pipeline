<script>
const STEPS = ["s1","s2","s3","s4"];

function setStep(n){
  STEPS.forEach((id,i)=>{
    const el=document.getElementById(id);
    el.className="step"+(i<n?" done":i===n?" active":"");
    el.querySelector(".step-num").textContent=i<n?"✓":i+1;
  });
}

function log(text,cls=""){
  const box=document.getElementById("log");
  const d=document.createElement("div");
  d.className=cls; d.textContent=text;
  box.appendChild(d);
  box.scrollTop=box.scrollHeight;
}

function classOf(t){
  if(t.includes("[MODULE"))      return "l-mod";
  if(t.includes("trained")||t.includes("saved")||t.includes("complete")||t.includes("Predictions")) return "l-ok";
  if(t.includes("[!]"))          return "l-warn";
  if(t.toLowerCase().includes("error")) return "l-err";
  return "";
}

function setMetric(id,val,good){
  const el=document.getElementById(id);
  el.textContent=val;
  el.className="m-val"+(good===true?" good":good===false?" bad":"");
}

async function runPipeline(){
  const btn=document.getElementById("run-btn");
  btn.disabled=true; btn.textContent="Running...";
  document.getElementById("log").innerHTML="";
  document.getElementById("results-img").style.display="none";
  document.getElementById("placeholder").style.display="block";
  ["m-acc","m-pp","m-np","m-auc","m-pnl"].forEach(id=>{
    const el=document.getElementById(id);
    el.textContent="—"; el.className="m-val";
  });
  setStep(-1);

  const params={
    csv:          document.getElementById("csv").value,
    max_rows:     document.getElementById("max_rows").value,
    t2:           document.getElementById("t2").value,
    model:        document.getElementById("model").value,
    lookback:     document.getElementById("lookback").value,
    threshold:    document.getElementById("threshold").value,
    use_relative: document.getElementById("use_relative").checked?1:0,
    train_as_test:document.getElementById("train_as_test").checked?1:0,
  };

  const resp=await fetch("/run",{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify(params)
  });

  const reader=resp.body.getReader();
  const dec=new TextDecoder();
  let buf="";

  while(true){
    const{done,value}=await reader.read();
    if(done) break;
    buf+=dec.decode(value,{stream:true});
    const lines=buf.split("\n");
    buf=lines.pop();
    for(const raw of lines){
      const line=raw.trim(); if(!line) continue;

      if(line.includes("[MODULE 1]")) setStep(0);
      if(line.includes("[MODULE 2]")) setStep(1);
      if(line.includes("[MODULE 3]")) setStep(2);
      if(line.includes("[MODULE 4]")) setStep(3);

      if(line.startsWith("METRICS:")){
        try{
          const m=JSON.parse(line.slice(8));
          setMetric("m-acc", m.overall_accuracy+"%",   m.overall_accuracy>=55);
          setMetric("m-pp",  m.precision_positive+"%", m.precision_positive>=50);
          setMetric("m-np",  m.precision_negative+"%", m.precision_negative>=50);
          setMetric("m-auc", m.roc_auc,                m.roc_auc>=0.55);
          const pnl=m.pnl;
          setMetric("m-pnl","$"+Math.abs(pnl).toLocaleString()+(pnl<0?" loss":" gain"), pnl>=0);
          setStep(4);
        }catch(e){}
        continue;
      }

      if(line.startsWith("IMAGE:")){
        const img=document.getElementById("results-img");
        img.src="data:image/png;base64,"+line.slice(6);
        img.style.display="block";
        document.getElementById("placeholder").style.display="none";
        continue;
      }

      log(line, classOf(line));
    }
  }

  btn.disabled=false; btn.textContent="▶  Run Pipeline";
}
</script>
</body>
