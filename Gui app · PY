# ── ROUTES ────────────────────────────────────────────────────────────────────

@app.route("/")
def index():
    return render_template_string(HTML)


@app.route("/run", methods=["POST"])
def run():
    p = request.get_json()

    # Resolve CSV path relative to pipeline directory if not absolute
    csv_path = p.get("csv", "TY.csv")
    if not os.path.isabs(csv_path):
        csv_path = os.path.join(HERE, csv_path)

    cmd = [
        sys.executable,
        os.path.join(HERE, "run_pipeline.py"),
        "--csv",           csv_path,
        "--max_rows",      str(p.get("max_rows", 5000)),
        "--t2",            p.get("t2", "2023-10-01"),
        "--model",         p.get("model", "svm"),
        "--lookback",      str(p.get("lookback", 4)),
        "--threshold",     str(p.get("threshold", 0.55)),
        "--use_relative",  str(p.get("use_relative", 1)),
        "--train_as_test", str(p.get("train_as_test", 0)),
        "--out_dir",       HERE,
    ]

    def stream():
        proc = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True, bufsize=1
        )
        for line in proc.stdout:
            yield line
        proc.wait()

        # Send metrics JSON
        if os.path.exists(METRICS_JSON):
            with open(METRICS_JSON) as f:
                yield f"METRICS:{f.read()}\n"

        # Send results image as base64
        if os.path.exists(RESULTS_IMG):
            with open(RESULTS_IMG, "rb") as f:
                yield f"IMAGE:{base64.b64encode(f.read()).decode()}\n"

    return Response(stream(), mimetype="text/plain",
                    headers={"X-Accel-Buffering": "no",
                             "Cache-Control": "no-cache"})


if __name__ == "__main__":
    print("\n" + "=" * 50)
    print("  Futures ML Pipeline  —  GUI")
    print("  Open browser at:  http://localhost:5000")
    print("=" * 50 + "\n")
    app.run(host="0.0.0.0", port=5000, debug=False, threaded=True)
