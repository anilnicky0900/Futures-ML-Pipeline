"""
MODULE 1 — DATA PREPARATION
============================
LLM Prompt used to generate this module:
  "I have minute-level futures data with columns: Date, Time, Open, High, Low,
   Close, VWAP, Volume, Up Ticks, Down Ticks, Same Ticks. Convert it into
   supervised learning format using a rolling lookback window of N minutes.
   For each window produce:
     (a) absolute OHLCV feature values
     (b) relative % change of every value vs the opening price of the window
   Target y = percentage change of next minute: (close - open) / open * 100.
   Include a flag use_relative to toggle relative features on/off.
   Return X (feature matrix), y (target vector), feature names, timestamps."

INPUT : csv_path (str), lookback (int), use_relative (bool), max_rows (int)
OUTPUT: X (ndarray shape [n, features]),
        y (ndarray shape [n]),
        feature_names (list of str),
        timestamps (list of Timestamps)
"""

import pandas as pd
import numpy as np

RAW_FEATURES = [
    "Open", "High", "Low", "Close", "VWAP",
    "Volume", "Up Ticks", "Down Ticks", "Same Ticks"
]


def load_data(csv_path: str, max_rows: int = None) -> pd.DataFrame:
    df = pd.read_csv(csv_path)
    df["Timestamp"] = pd.to_datetime(df["Date and Time"], dayfirst=False)
    df = df.sort_values("Timestamp").reset_index(drop=True)
    for col in RAW_FEATURES:
        df[col] = pd.to_numeric(df[col], errors="coerce")
    df = df.dropna(subset=RAW_FEATURES).reset_index(drop=True)
    if max_rows:
        df = df.head(max_rows)
    return df


def build_feature_matrix(df: pd.DataFrame,
                          lookback: int = 4,
                          use_relative: bool = True):
    """
    For each time step i, look back `lookback` minutes for features.
    Target is the % price change of minute i.
    """
    abs_names = [f"{col}_t-{lookback-j}"
                 for j in range(lookback) for col in RAW_FEATURES]
    rel_names = [f"{col}_pct_t-{lookback-j}"
                 for j in range(lookback) for col in RAW_FEATURES]

    X_abs, X_rel, y_vals, timestamps = [], [], [], []

    for i in range(lookback, len(df) - 1):
        window   = df.iloc[i - lookback: i]
        ref_open = window.iloc[0]["Open"]

        abs_vec = window[RAW_FEATURES].values.flatten().tolist()
        rel_vec = ([(v - ref_open) / ref_open * 100 for v in abs_vec]
                   if ref_open != 0 else [0.0] * len(abs_vec))

        t_open  = df.iloc[i]["Open"]
        t_close = df.iloc[i]["Close"]
        target  = (t_close - t_open) / t_open * 100 if t_open != 0 else 0.0

        X_abs.append(abs_vec)
        X_rel.append(rel_vec)
        y_vals.append(target)
        timestamps.append(df.iloc[i]["Timestamp"])

    Xa = np.array(X_abs, dtype=np.float64)
    Xr = np.array(X_rel, dtype=np.float64)
    y  = np.array(y_vals, dtype=np.float64)

    if use_relative:
        X            = np.hstack([Xa, Xr])
        feature_names = abs_names + rel_names
    else:
        X            = Xa
        feature_names = abs_names

    mask = np.isfinite(X).all(axis=1) & np.isfinite(y)
    ts_out = [timestamps[k] for k in range(len(mask)) if mask[k]]
    return X[mask], y[mask], feature_names, ts_out


def time_split(X, y, timestamps, t2_str: str):
    """
    Split dataset at date T2.
    Train = before T2,  Test = from T2 onward.
    Falls back to 70/30 index split if T2 is outside the data range.
    """
    train_idx, test_idx = [], []
    fallback = False

    if t2_str:
        t2 = pd.Timestamp(t2_str)
        train_idx = [i for i, t in enumerate(timestamps) if t < t2]
        test_idx  = [i for i, t in enumerate(timestamps) if t >= t2]
        if not train_idx or not test_idx:
            fallback = True

    if not t2_str or fallback:
        split     = int(0.7 * len(X))
        train_idx = list(range(split))
        test_idx  = list(range(split, len(X)))
        if fallback:
            print(f"  [!] T2 outside data range — using 70/30 split instead")

    return (X[train_idx], y[train_idx],
            X[test_idx],  y[test_idx],
            train_idx, test_idx)
